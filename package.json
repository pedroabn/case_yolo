{
  "name": "yolo-coliving",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"flask,vite\" -c \"blue,green\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "echo 'Servidor local removido, usando API Gateway diretamente'",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "install:py": "pip install -r backend/requirements.txt --break-system-packages",
    "deploy": "pip install -r requirements.txt --target dep/ && serverless deploy"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1018.0",
    "@aws-sdk/lib-dynamodb": "^3.1018.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}