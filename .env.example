# URL do API Gateway gerada após o deploy das funções Lambda
# Exemplo: https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_API_URL=

# Credenciais AWS (necessárias apenas para scripts locais como create_table.py)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Nome da tabela DynamoDB (deve coincidir com o TABLE_NAME da Lambda)
DYNAMODB_TABLE_NAME=yolo-coliving-api-people-table
